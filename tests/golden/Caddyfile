{
	default_sni test.example
	servers {
		metrics
	}
}

(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' wss: https:; frame-ancestors 'none'"
		-Server
	}
}

(common_log) {
	log {
		output stdout
		format json
		level INFO
	}
}

# Niles AI
niles.test.example {
	tls internal
	import security_headers
	import common_log
	reverse_proxy niles_core:8000
}

# PulseBase
garmin.test.example {
	tls internal
	import security_headers
	import common_log
	reverse_proxy pulsebase-api:8000
}

# Vikunja (Todos)
vikunja.test.example {
	tls internal
	import security_headers
	import common_log
	reverse_proxy vikunja:3456
}

# Evolution API (WhatsApp)
whatsapp.test.example {
	tls internal
	import security_headers
