{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Digest/patch automerge ohne Schedule (CI validiert, Homelab toleriert Restarts). Minor/major erfordern manuellen Review.",
  "extends": ["config:recommended"],
  "pinDigests": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "GitHub Actions patch-Updates: sicher, automatisch mergen",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "GitHub Actions minor/major-Updates: manueller Review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["dependencies", "review-needed"]
    },
    {
      "description": "Docker Digest- und Patch-Updates: sicher, automatisch mergen",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["digest", "patch"],
      "automerge": true
    },
    {
      "description": "Docker minor/major-Updates: manueller Review",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["dependencies", "review-needed"]
    }
  ]
}
