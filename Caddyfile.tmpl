{
	default_sni ${DOMAIN}
	servers {
		metrics
	}
}

(common_security) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

(security_headers) {
	import common_security
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'"
	}
}

(security_headers_relaxed) {
	import common_security
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' data:; font-src 'self' data:; connect-src 'self' wss: https:; frame-ancestors 'none'"
	}
}

# Für Apps, die einen eigenen (besseren) CSP mitbringen: nur die Basis-Header,
# KEIN Content-Security-Policy am Gateway. Caddys `header`-Direktive würde den
# Upstream-CSP sonst ersetzen — hier reichen wir den App-CSP unverändert durch
# (z. B. PulseBase: nonce-basiert mit 'strict-dynamic', strenger als ein
# statischer Gateway-CSP).
(security_headers_app_csp) {
	import common_security
}

# arbscanner-Dashboard: lädt HTMX (unpkg.com) und Tailwind (cdn.tailwindcss.com) via CDN.
# script-src muss diese beiden externen Quellen explizit erlauben.
(security_headers_arb) {
	import common_security
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://cdn.tailwindcss.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self'; frame-ancestors 'none'"
	}
}

(common_log) {
	log {
		output stdout
		format json
		level INFO
	}
}

# HTTP-to-HTTPS redirect
http://*.${DOMAIN} {
	redir https://{host}{uri} permanent
}

# Niles AI — bringt eigenen nonce-basierten CSP mit (siehe security_headers_app_csp)
niles.${DOMAIN} {
	tls internal
	import security_headers_app_csp
	import common_log
	reverse_proxy {$NILES_UPSTREAM:niles_core:8000}
}

# PulseBase — bringt eigenen nonce-basierten CSP mit (siehe security_headers_app_csp)
garmin.${DOMAIN} {
	tls internal
	import security_headers_app_csp
	import common_log
	reverse_proxy {$PULSEBASE_UPSTREAM:pulsebase-api:8000}
}

# Vikunja (Todos) — Third-Party-App, braucht unsafe-inline für Styles
vikunja.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy {$VIKUNJA_UPSTREAM:vikunja:3456}
}

# Evolution API (WhatsApp)
whatsapp.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	reverse_proxy {$WHATSAPP_UPSTREAM:evolution_api:8080}
}

# Uptime Kuma (Status Page)
status.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy {$UPTIME_UPSTREAM:gateway-uptime:3001}
}

# Grafana (Logs)
logs.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy {$GRAFANA_UPSTREAM:gateway-grafana:3000}
}

# Gitea (Git hosting)
gitea.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy {$GITEA_UPSTREAM:gitea:3000}
}

# Prometheus (Metrics UI) — password protected
prometheus.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	basicauth {
		{$CADDY_AUTH_USER} {$CADDY_AUTH_PASS_HASH}
	}
	reverse_proxy {$PROMETHEUS_UPSTREAM:prometheus:9090}
}

# Caddy Metrics — password protected
metrics.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	basicauth {
		{$CADDY_AUTH_USER} {$CADDY_AUTH_PASS_HASH}
	}
	reverse_proxy localhost:9180
}

# arbscanner (Prediction Market Arbitrage Dashboard)
arb.${DOMAIN} {
	tls internal
	import security_headers_arb
	import common_log
	reverse_proxy {$ARBSCANNER_UPSTREAM:arbscanner:8000}
}

# Prometheus scrape endpoint (internal only)
:9180 {
	metrics /metrics
}

# Niles /metrics scrape (internal only, monitoring network).
# Niles protects /metrics with an X-API-Key header and exposes no host port,
# so Prometheus (monitoring net) cannot reach it directly. Caddy bridges to
# niles_core (proxy net) and injects the key, keeping the secret out of the
# Prometheus config. Reachable only as caddy:9101 inside Docker.
:9101 {
	@metrics path /metrics
	handle @metrics {
		reverse_proxy {$NILES_UPSTREAM:niles_core:8000} {
			header_up X-API-Key {$NILES_METRICS_API_KEY}
		}
	}
	respond 404
}
