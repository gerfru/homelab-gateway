{
	default_sni ${DOMAIN}
	servers {
		metrics
	}
}

(common_security) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

(security_headers) {
	import common_security
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'"
	}
}

(security_headers_relaxed) {
	import common_security
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' wss: https:; frame-ancestors 'none'"
	}
}

(common_log) {
	log {
		output stdout
		format json
		level INFO
	}
}

# Niles AI
niles.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	reverse_proxy niles_core:8000
}

# PulseBase
garmin.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	reverse_proxy pulsebase-api:8000
}

# Vikunja (Todos)
vikunja.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	reverse_proxy vikunja:3456
}

# Evolution API (WhatsApp)
whatsapp.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	reverse_proxy evolution_api:8080
}

# Uptime Kuma (Status Page)
status.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy gateway-uptime:3001
}

# Grafana (Logs)
logs.${DOMAIN} {
	tls internal
	import security_headers_relaxed
	import common_log
	reverse_proxy gateway-grafana:3000
}

# Prometheus (Metrics UI) — password protected
prometheus.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	basicauth {
		{$CADDY_AUTH_USER} {$CADDY_AUTH_PASS_HASH}
	}
	reverse_proxy prometheus:9090
}

# Caddy Metrics — password protected
metrics.${DOMAIN} {
	tls internal
	import security_headers
	import common_log
	basicauth {
		{$CADDY_AUTH_USER} {$CADDY_AUTH_PASS_HASH}
	}
	reverse_proxy localhost:9180
}

# Prometheus scrape endpoint (internal only)
:9180 {
	metrics /metrics
}
