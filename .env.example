# Your machine's Tailscale IPv4 address
# Find it with: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# Internal domain suffix (used in CoreDNS + Caddy)
DOMAIN=home.lab

# MagicDNS hostname for Niles (used in Caddyfile for Google OAuth)
# Format: <machine-name>.<tailnet-id>.ts.net
# Find it at: https://login.tailscale.com/admin/machines
NILES_TS_HOSTNAME=your-machine.your-tailnet.ts.net

# Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Uptime Kuma credentials (for monitor provisioning)
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=changeme
