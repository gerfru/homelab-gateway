# Your machine's Tailscale IPv4 address
# Find it with: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# Internal domain suffix (used in CoreDNS + Caddy)
DOMAIN=home.lab

# Grafana admin credentials — now stored as Docker Secrets
# See secrets/README.md for setup instructions
#   echo -n "admin" > secrets/gf_admin_user
#   echo -n "your-strong-password" > secrets/gf_admin_password

# Uptime Kuma credentials (used by scripts/setup-uptime-monitors.sh, not by the container)
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Grafana alerting webhook URL (RECOMMENDED — alerts fail silently without this)
ALERTING_WEBHOOK_URL=https://your-webhook-url

# Caddy basicauth for monitoring subdomains (prometheus, metrics)
# STRONGLY RECOMMENDED — without this, Prometheus and metrics endpoints are unprotected
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
# IMPORTANT: Wrap hash in single quotes (bcrypt $ signs break Docker Compose interpolation)
CADDY_AUTH_USER=admin
CADDY_AUTH_PASS_HASH=CHANGE_ME_GENERATE_WITH: docker run --rm caddy:2-alpine caddy hash-password

# Sentry DSN for error tracking (create project at sentry.io)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
