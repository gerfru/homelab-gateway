# Your machine's Tailscale IPv4 address
# Find it with: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# Internal domain suffix (used in CoreDNS + Caddy)
DOMAIN=home.lab

# Grafana admin credentials — now stored as Docker Secrets
# See secrets/README.md for setup instructions
#   echo -n "admin" > secrets/gf_admin_user
#   echo -n "your-strong-password" > secrets/gf_admin_password

# Uptime Kuma credentials (used by scripts/setup-uptime-monitors.sh, not by the container)
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Grafana alerting webhook URL (RECOMMENDED — alerts fail silently without this)
ALERTING_WEBHOOK_URL=https://your-webhook-url

# Caddy basicauth for monitoring subdomains (prometheus, metrics)
# STRONGLY RECOMMENDED — without this, Prometheus and metrics endpoints are unprotected
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
# IMPORTANT: Wrap hash in single quotes (bcrypt $ signs break Docker Compose interpolation)
CADDY_AUTH_USER=admin
CADDY_AUTH_PASS_HASH=CHANGE_ME_GENERATE_WITH: docker run --rm caddy:2-alpine caddy hash-password

# Niles /metrics scrape (Prometheus → Caddy :9101 → niles_core, key injected by Caddy).
# Must equal Niles' own NILES_API_KEY. Leave empty to disable Niles metrics scraping.
#
# IMPORTANT: NILES_API_KEY must be set to a STABLE value in Niles' own .env.
# If left empty there, Niles auto-generates a new key on every container start
# (secrets.token_urlsafe), so this value would go stale on each Niles restart
# and the scrape would start failing with 401. Generate once and use the same
# value on both sides:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
NILES_METRICS_API_KEY=

# Retention (optional — sensible defaults built in)
# PROMETHEUS_RETENTION_TIME=30d
# PROMETHEUS_RETENTION_SIZE=500MB
# LOKI_RETENTION_PERIOD=336h

# Backing service upstreams (optional — defaults are built in)
# NILES_UPSTREAM=niles_core:8000
# PULSEBASE_UPSTREAM=pulsebase-api:8000
# VIKUNJA_UPSTREAM=vikunja:3456
# WHATSAPP_UPSTREAM=evolution_api:8080
# UPTIME_UPSTREAM=gateway-uptime:3001
# GRAFANA_UPSTREAM=gateway-grafana:3000
# PROMETHEUS_UPSTREAM=prometheus:9090
# GITEA_UPSTREAM=gitea:3000

# Gitea credentials — stored as Docker Secrets
# See secrets/README.md for setup instructions
#   echo -n "your-db-password" > secrets/gitea_db_password
#   echo -n "your-admin-password" > secrets/gitea_admin_password
#   echo -n "your-renovate-token" > secrets/renovate_token

# GitHub mirror (required for daily mirror push to GitHub)
# Generate: GitHub → Settings → Developer Settings → Personal Access Tokens (classic)
# Scopes: repo (full)
GITHUB_MIRROR_TOKEN=ghp_CHANGE_ME
GITHUB_MIRROR_OWNER=your-github-username

# GitHub → Gitea sync (used by scripts/github-to-gitea-sync.sh)
# Generate token at: https://your-gitea-instance → Settings → Applications → Access Tokens
# Scopes: repository (read+write), user (read)
# GITEA_TOKEN=CHANGE_ME
GITEA_USER=your-gitea-username
GITHUB_USER=your-github-username

# Path to PulseBase .env file (used by scripts/update-ip.sh to sync TAILSCALE_IP)
# Only needed if you run PulseBase alongside this gateway
# PULSEBASE_ENV=/path/to/pulsebase/env/.env

# Docker Compose project name (affects volume/network prefixes)
# COMPOSE_PROJECT_NAME=homelab-gateway
