{
  "uid": "system-monitoring",
  "title": "System Monitoring",
  "tags": ["homelab", "system", "prometheus"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=~\"/var/lib|/run/host_virtiofs/Users\",fstype=~\"ext4|virtiofs.*\"} / node_filesystem_size_bytes{mountpoint=~\"/var/lib|/run/host_virtiofs/Users\",fstype=~\"ext4|virtiofs.*\"} * 100)",
          "legendFormat": "{{ mountpoint }}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "RAM Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_memory_available_bytes / node_memory_total_bytes) * 100",
          "legendFormat": "RAM",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Disk Space (all mounts)",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{fstype=~\"ext4|virtiofs.*\"}",
          "legendFormat": "{{ mountpoint }}",
          "refId": "size",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "node_filesystem_avail_bytes{fstype=~\"ext4|virtiofs.*\"}",
          "legendFormat": "{{ mountpoint }}",
          "refId": "avail",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "100 - (node_filesystem_avail_bytes{fstype=~\"ext4|virtiofs.*\"} / node_filesystem_size_bytes{fstype=~\"ext4|virtiofs.*\"} * 100)",
          "legendFormat": "{{ mountpoint }}",
          "refId": "pct",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "max", "value": 100 },
              { "id": "thresholds", "value": { "steps": [{ "value": null, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 85, "color": "red" }] } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value #pct", "desc": true }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "device": true, "instance": true, "job": true },
            "renameByName": { "mountpoint": "Mount", "fstype": "Type", "Value #size": "Total", "Value #avail": "Available", "Value #pct": "Used %" }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage (over time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (mode) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "id": 6,
      "title": "RAM Usage (over time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_total_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_total_bytes - node_memory_available_bytes",
          "legendFormat": "Used",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{device!~\"dm-.*\"}[5m])",
          "legendFormat": "Read {{ device }}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{device!~\"dm-.*\"}[5m])",
          "legendFormat": "Write {{ device }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "RX {{ device }}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "TX {{ device }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 9,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_time_seconds - node_boot_time_seconds",
          "legendFormat": "Uptime",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "Load Average (1m / 5m / 15m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m",
          "refId": "C",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 4, "color": "yellow" },
              { "value": 8, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 11,
      "title": "Docker VM Free",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/var/lib\",fstype=\"ext4\"}",
          "legendFormat": "Free",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "value": null, "color": "red" },
              { "value": 5368709120, "color": "yellow" },
              { "value": 21474836480, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    }
  ],
  "schemaVersion": 39
}
