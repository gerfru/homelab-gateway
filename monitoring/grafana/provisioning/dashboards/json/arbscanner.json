{
  "uid": "arbscanner",
  "title": "arbscanner — Arbitrage Scanner",
  "tags": ["arbscanner", "loki", "trading"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scan Cycles (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | event=\"scan_cycle_complete\" [1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 1, "color": "green" }
            ]
          },
          "unit": "short",
          "displayName": "Scans"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Opportunities Found (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | event=\"opportunity_found\" [1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 1, "color": "green" }
            ]
          },
          "unit": "short",
          "displayName": "Opportunities"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Errors (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | level=\"error\" [1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "unit": "short",
          "displayName": "Errors"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "Scanner Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | event=\"bot_started\" [5m])",
          "refId": "A",
          "legendFormat": "running"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "unit": "short",
          "displayName": "Scanner"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "offline", "color": "red", "index": 0 } } },
                  { "type": "range", "options": { "from": 1, "to": 9999, "result": { "text": "running", "color": "green" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": { "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 5,
      "title": "Scan Activity",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | event=\"scan_cycle_complete\" [$__auto])",
          "legendFormat": "scan cycles",
          "refId": "A"
        },
        {
          "expr": "count_over_time({container=\"arbscanner\"} | json | event=\"opportunity_found\" [$__auto])",
          "legendFormat": "opportunities",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "none" } },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "opportunities" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Market Coverage (latest scan)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "max_over_time({container=\"arbscanner\"} | json | event=\"scan_cycle_complete\" | unwrap kalshi_count [$__auto])",
          "legendFormat": "Kalshi markets",
          "refId": "A"
        },
        {
          "expr": "max_over_time({container=\"arbscanner\"} | json | event=\"scan_cycle_complete\" | unwrap poly_count [$__auto])",
          "legendFormat": "Poly markets",
          "refId": "B"
        },
        {
          "expr": "max_over_time({container=\"arbscanner\"} | json | event=\"scan_cycle_complete\" | unwrap matched_count [$__auto])",
          "legendFormat": "matched pairs",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "Opportunities Log",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 11 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=\"arbscanner\"} | json | event=\"opportunity_found\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 8,
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=\"arbscanner\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39
}
