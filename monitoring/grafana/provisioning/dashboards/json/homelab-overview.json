{
  "uid": "homelab-overview",
  "title": "Homelab Overview",
  "tags": ["homelab", "loki"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": { "type": "loki", "uid": "" },
        "query": { "type": 1, "label": "project", "stream": "" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "" },
        "query": { "type": 1, "label": "container", "stream": "{project=~\"$project\"}" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Project",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (project) (count_over_time({project=~\"$project\"} [$__auto]))",
          "legendFormat": "{{ project }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Errors by Container",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({project=~\"$project\"} |~ \"(?i)error|exception|traceback|critical\" [$__auto]))",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic-by-name" },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Log Volume by Container",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({project=~\"$project\", container=~\"$container\"} [$__auto]))",
          "legendFormat": "{{ container }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (per minute)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({project=~\"$project\"} |~ \"(?i)error|exception|traceback|critical\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Active Containers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count(count by (container) (count_over_time({project=~\"$project\"} [5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "blue" }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Top Errors",
      "type": "table",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "topk(10, sum by (container) (count_over_time({project=~\"$project\"} |~ \"(?i)error|exception|traceback|critical\" [1h])))",
          "legendFormat": "{{ container }}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    },
    {
      "id": 10,
      "title": "Live Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{project=~\"$project\", container=~\"$container\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39
}
